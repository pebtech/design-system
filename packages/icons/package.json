{
  "name": "@peb/icons",
  "version": "0.0.1",
  "description": "Icon library for the PEB design system",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./outline": {
      "types": "./dist/outline.d.ts",
      "import": "./dist/outline.mjs",
      "require": "./dist/outline.cjs"
    },
    "./solid": {
      "types": "./dist/solid.d.ts",
      "import": "./dist/solid.mjs",
      "require": "./dist/solid.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "generate": "node scripts/generate-icons.mjs",
    "build": "node scripts/generate-icons.mjs && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "10 kB",
      "gzip": true
    }
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
