{
  "name": "@peb/ui-web",
  "version": "0.0.1",
  "description": "Web UI components for the PEB design system",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/tailwind.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "35 kB",
      "gzip": true
    }
  ],
  "peerDependencies": {
    "@headlessui/react": "^2.2.0",
    "date-fns": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@peb/tokens": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@headlessui/react": "^2.2.9",
    "@types/react": "^19.2.15",
    "date-fns": "^4.1.0",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
