{
  "name": "@pebtech/ui-web",
  "version": "0.0.1",
  "description": "Web UI components for the PEB design system",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./src/styles/tailwind.css"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pebtech/design-system.git",
    "directory": "packages/ui-web"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "size": "size-limit"
  },
  "//size-limit-note": "react/react-dom/@headlessui/react/react-aria/react-stately/date-fns/tailwindcss are peer deps and are ignored here. The limit covers ui-web's own component code plus its bundled runtime deps (clsx, tailwind-merge, @pebtech/tokens).",
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "40 kB",
      "gzip": true,
      "ignore": [
        "react",
        "react-dom",
        "@headlessui/react",
        "react-aria",
        "react-stately",
        "date-fns",
        "tailwindcss"
      ]
    }
  ],
  "peerDependencies": {
    "date-fns": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-aria": "^3.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-stately": "^3.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.5",
    "@pebtech/tokens": "workspace:*",
    "@headlessui/react": "^2.2.10",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "date-fns": "^4.1.0",
    "react": "^19.2.6",
    "react-aria": "^3.48.0",
    "react-dom": "^19.0.0",
    "react-stately": "^3.46.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
