{
  "expo": {
    "name": "PEB Native Storybook",
    "slug": "peb-native-storybook",
    "scheme": "peb-native-storybook",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": ["expo-dev-client", "./plugins/withFmtXcode26Fix.js"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pebtech.native-storybook"
    },
    "android": {
      "package": "com.pebtech.nativestorybook"
    }
  }
}
