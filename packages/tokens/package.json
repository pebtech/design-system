{
  "name": "@pebtech/tokens",
  "version": "0.0.1",
  "description": "Design tokens for the PEB design system",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./css": "./dist/css/tokens.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pebtech/design-system.git",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup && node scripts/generate-css.mjs && node scripts/check-parity.mjs",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "check-parity": "node scripts/check-parity.mjs",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "5 kB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
