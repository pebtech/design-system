{
  "name": "@pebtech/ui-native",
  "version": "0.0.1",
  "description": "React Native UI components for the PEB design system (Phase 2 — gated on NativeWind v5 stable)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pebtech/design-system.git",
    "directory": "packages/ui-native"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "size": "echo 'no size check yet'"
  },
  "peerDependencies": {
    "nativewind": ">=5.0.0-preview.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.76.0"
  },
  "dependencies": {
    "@pebtech/tokens": "workspace:*",
    "@react-native-aria/switch": "^0.2.4",
    "clsx": "^2.1.1",
    "react-native-aria": "^0.2.3",
    "react-stately": "^3.46.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
