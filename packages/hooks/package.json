{
  "name": "@pebtech/hooks",
  "version": "0.0.1",
  "description": "Shared React hooks for the PEB design system",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pebtech/design-system.git",
    "directory": "packages/hooks"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "3 kB",
      "gzip": true
    }
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "UNLICENSED"
}
