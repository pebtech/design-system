@pebtech:registry=https://npm.pkg.github.com
# Auth: set GITHUB_TOKEN env var, or add an authToken line to ~/.npmrc:
#   //npm.pkg.github.com/:_authToken=YOUR_TOKEN
# CI sets GITHUB_TOKEN via env. The pnpm fail-on-empty-env behavior is silenced
# by removing the inline ${GITHUB_TOKEN} reference.

# Security
auto-install-peers=false
resolution-mode=highest

# Script control is in package.json pnpm.onlyBuiltDependencies
